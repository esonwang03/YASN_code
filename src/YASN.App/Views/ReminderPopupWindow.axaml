<Window
    x:Class="YASN.Views.ReminderPopupWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:l="clr-namespace:YASN.Localization"
    xmlns:webview="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.WebView"
    Width="360"
    Height="280"
    Topmost="True"
    ShowInTaskbar="False"
    CanResize="True"
    WindowDecorations="Full"
    Icon="avares://YASN/Resources/YASN.ico"
    Title="{l:Tr Reminder.Window.Title}">
  <DockPanel Margin="0">
    <Border DockPanel.Dock="Top" Background="#3D7EFF" Padding="12,8">
      <TextBlock x:Name="HeaderText" Foreground="White" FontWeight="SemiBold" FontSize="14"
                 TextTrimming="CharacterEllipsis" />
    </Border>
    <Border DockPanel.Dock="Bottom" Padding="12,8">
      <Button x:Name="DismissButton" HorizontalAlignment="Right"
              Content="{l:Tr Reminder.Window.Dismiss}" Click="HandleDismissClick" />
    </Border>
    <webview:NativeWebView x:Name="ReminderWebView" />
  </DockPanel>
</Window>
