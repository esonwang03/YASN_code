<Window
    x:Class="YASN.Views.FloatingNoteWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:YASN.ViewModels"
    xmlns:l="clr-namespace:YASN.Localization"
    xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:ae="https://github.com/avaloniaui/avaloniaedit"
    xmlns:webview="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.WebView"
    x:DataType="vm:NoteWindowViewModel"
    WindowDecorations="None"
    Icon="avares://YASN/Resources/YASN.ico"
    Title="{Binding Title}"
    Width="900"
    Height="560"
    MinHeight="380">
  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="NoteTitleBarBackground">#F7F7F8</SolidColorBrush>
          <SolidColorBrush x:Key="NoteChromeBorder">#D0D0D0</SolidColorBrush>
          <SolidColorBrush x:Key="NoteSecondaryText">#666666</SolidColorBrush>
          <SolidColorBrush x:Key="NoteResizeGrip">#9A9A9A</SolidColorBrush>
          <SolidColorBrush x:Key="NotePreviewBackground">#FFFFFF</SolidColorBrush>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="NoteTitleBarBackground">#2B2B2B</SolidColorBrush>
          <SolidColorBrush x:Key="NoteChromeBorder">#3F3F3F</SolidColorBrush>
          <SolidColorBrush x:Key="NoteSecondaryText">#AAAAAA</SolidColorBrush>
          <SolidColorBrush x:Key="NoteResizeGrip">#777777</SolidColorBrush>
          <SolidColorBrush x:Key="NotePreviewBackground">#1E1E1E</SolidColorBrush>
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
      <!-- Invisible-but-hittable template for the borderless-window edge/corner resize thumbs: a
           transparent Border is hit-testable (unlike a null background) yet draws nothing. -->
      <ControlTemplate x:Key="InvisibleThumbTemplate" TargetType="Thumb">
        <Border Background="Transparent" />
      </ControlTemplate>
    </ResourceDictionary>
  </Window.Resources>
  <!-- Keep the title bar and native preview host in separate layout rows. Native WebView hosts can
       draw outside Avalonia overlay ordering on macOS, so structural layout is the stable boundary.
       The root grid background fills the resize gutter reserved around the body (see BodyContent's
       margin) so the edge/corner thumbs there are never covered by the native WebView. -->
  <Grid RowDefinitions="Auto,*" Background="{DynamicResource NoteTitleBarBackground}">
    <Border
        x:Name="TitleBar"
        Grid.Row="0"
        Padding="12,8"
        Background="{DynamicResource NoteTitleBarBackground}"
        BorderBrush="{DynamicResource NoteChromeBorder}"
        BorderThickness="0,0,0,1">
      <Border.ContextFlyout>
        <MenuFlyout>
          <MenuItem Header="{l:Tr Window.ToggleChrome}" Click="HandleToggleChromeClick" />
          <MenuItem Header="{l:Tr Window.EditExternal}" Click="HandleEditExternalClick" />
          <MenuItem Header="{l:Tr Rename.MenuItem}" Click="HandleRenameClick" />
          <MenuItem Header="{l:Tr Window.Menu.Manage}" Click="MenuItem_OnClick"></MenuItem>
        </MenuFlyout>
      </Border.ContextFlyout>
      <Grid ColumnDefinitions="*,Auto,Auto,Auto">
        <StackPanel>
          <TextBlock Text="{l:Tr App.Title}" FontSize="13" FontWeight="SemiBold" />
          <TextBlock Text="{Binding Title}" FontSize="12" Foreground="{DynamicResource NoteSecondaryText}" />
        </StackPanel>
        <ComboBox x:Name="LevelSelector" Grid.Column="1" Width="120" Margin="0,0,8,0" />
        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8">
          <Button x:Name="EditorModeButton" ToolTip.Tip="{l:Tr Window.EditorMode.Hint}" Click="HandleEditorModeClick">
            <mi:MaterialIcon x:Name="EditorModeIcon" Width="18" Height="18" />
          </Button>
          <Button ToolTip.Tip="{l:Tr Window.QuickLayout.Hint}" Click="HandleQuickLayoutClick">
            <mi:MaterialIcon Kind="ViewDashboardOutline" Width="18" Height="18" />
          </Button>
          <Button ToolTip.Tip="{l:Tr Window.SetReminder}" Click="HandleSetReminderClick">
            <mi:MaterialIcon Kind="BellOutline" Width="18" Height="18" />
          </Button>
          <Button x:Name="FullScreenButton" ToolTip.Tip="{l:Tr Window.FullScreen.Hint}" Click="HandleFullScreenClick">
            <mi:MaterialIcon x:Name="FullScreenIcon" Kind="Fullscreen" Width="18" Height="18" />
          </Button>
          <Button x:Name="MaximizeButton" ToolTip.Tip="{l:Tr Window.Maximize.Hint}" Click="HandleMaximizeClick">
            <mi:MaterialIcon x:Name="MaximizeIcon" Kind="WindowMaximize" Width="18" Height="18" />
          </Button>
          <Button ToolTip.Tip="{l:Tr Window.Close}" Click="HandleCloseClick">
            <mi:MaterialIcon Kind="Close" Width="18" Height="18" />
          </Button>
        </StackPanel>
      </Grid>
    </Border>
    <!-- Left/right/bottom margin reserves a resize gutter the native WebView cannot cover, so the
         edge/corner thumbs below stay hittable. No top gutter: the top edge overlaps the title bar. -->
    <Grid x:Name="BodyContent" Grid.Row="1" ColumnDefinitions="*,*" Margin="6,0,6,6">
      <DockPanel x:Name="EditorPanel" Grid.Column="0">
        <StackPanel
            x:Name="EditorToolbar"
            DockPanel.Dock="Top"
            Orientation="Horizontal"
            Spacing="6"
            Margin="8,6">
          <Button x:Name="InsertImageButton" ToolTip.Tip="{l:Tr Editor.InsertImage}" Click="HandleInsertImageClick">
            <mi:MaterialIcon Kind="Image" Width="18" Height="18" />
          </Button>
          <Button x:Name="InsertAttachmentButton" ToolTip.Tip="{l:Tr Editor.InsertAttachment}" Click="HandleInsertAttachmentClick">
            <mi:MaterialIcon Kind="Paperclip" Width="18" Height="18" />
          </Button>
        </StackPanel>
        <ae:TextEditor
            x:Name="EditorTextEditor"
            WordWrap="True"
            FontFamily="Consolas"
            FontSize="14"
            Padding="14">
          <ae:TextEditor.ContextFlyout>
            <MenuFlyout>
              <MenuItem Header="Cut" InputGesture="Ctrl+X" Click="HandleEditorCutClick" />
              <MenuItem Header="Copy" InputGesture="Ctrl+C" Click="HandleEditorCopyClick" />
              <MenuItem Header="Paste" InputGesture="Ctrl+V" Click="HandleEditorPasteClick" />
              <MenuItem Header="-" />
              <MenuItem Header="Bold" InputGesture="Ctrl+B" Click="HandleEditorBoldClick" />
              <MenuItem Header="Italic" InputGesture="Ctrl+I" Click="HandleEditorItalicClick" />
              <MenuItem Header="Inline Code" Click="HandleEditorInlineCodeClick" />
              <MenuItem Header="Format">
                <MenuItem Header="Strikethrough" Click="HandleEditorStrikethroughClick" />
                <MenuItem Header="Inserted" Click="HandleEditorInsertClick" />
                <MenuItem Header="Highlight" Click="HandleEditorHighlightClick" />
                <MenuItem Header="Superscript" Click="HandleEditorSuperscriptClick" />
                <MenuItem Header="Subscript" Click="HandleEditorSubscriptClick" />
              </MenuItem>
              <MenuItem Header="Link" Click="HandleEditorLinkClick" />
              <MenuItem Header="Quote" Click="HandleEditorQuoteClick" />
              <MenuItem Header="Task Checkbox" Click="HandleEditorTaskCheckboxClick" />
              <MenuItem Header="Paragraph">
                <MenuItem Header="Above" Click="HandleEditorParagraphAboveClick" />
                <MenuItem Header="Below" Click="HandleEditorParagraphBelowClick" />
              </MenuItem>
              <MenuItem Header="Insert">
                <MenuItem Header="Table" Click="HandleEditorInsertTableClick" />
                <MenuItem Header="Fenced Code Block" Click="HandleEditorInsertCodeBlockClick" />
                <MenuItem Header="Math Block" Click="HandleEditorInsertMathBlockClick" />
                <MenuItem Header="Footnote" Click="HandleEditorInsertFootnoteClick" />
                <MenuItem Header="Horizontal Rule" Click="HandleEditorInsertHorizontalRuleClick" />
                <MenuItem Header="Color Text" Click="HandleEditorInsertColorTextClick" />
                <MenuItem Header="Reminder" Click="HandleEditorInsertReminderClick" />
              </MenuItem>
            </MenuFlyout>
          </ae:TextEditor.ContextFlyout>
        </ae:TextEditor>
      </DockPanel>
      <Border x:Name="PreviewPanel" Grid.Column="1" Background="{DynamicResource NotePreviewBackground}" BorderBrush="{DynamicResource NoteChromeBorder}" BorderThickness="1,0,0,0">
        <webview:NativeWebView x:Name="PreviewWebView" />
      </Border>
      <!-- Bottom-right resize grip, mirroring the WPF ResizeThumb. Drives the window's native
           resize loop so the editor and preview reflow live during the drag. -->
      <Thumb
          x:Name="ResizeGrip"
          Grid.Column="0"
          Grid.ColumnSpan="2"
          Width="16"
          Height="16"
          HorizontalAlignment="Right"
          VerticalAlignment="Bottom"
          Background="Transparent"
          Cursor="BottomRightCorner"
          ToolTip.Tip="{l:Tr Window.Resize.Grip}">
        <Thumb.Template>
          <ControlTemplate>
            <Path
                Data="M 11,0 L 16,5 16,16 5,16 Z"
                Fill="{DynamicResource NoteResizeGrip}"
                Stretch="Fill"
                Margin="3" />
          </ControlTemplate>
        </Thumb.Template>
      </Thumb>
    </Grid>
    <!-- Borderless-window edge/corner resize handles. Thin transparent thumbs overlaid on the window
         edges each drive the native resize loop for one WindowEdge, giving side and corner resizing that
         a WindowDecorations="None" window has no OS chrome for. Corners are declared after edges so they
         win hit-testing where they overlap. The bottom-right corner is served by the visible ResizeGrip
         above, so it is omitted here. -->
    <Thumb x:Name="ResizeLeft" Grid.Row="0" Grid.RowSpan="2" Template="{StaticResource InvisibleThumbTemplate}"
           Width="6" HorizontalAlignment="Left" VerticalAlignment="Stretch" Margin="0,12" Cursor="LeftSide" />
    <Thumb x:Name="ResizeRight" Grid.Row="0" Grid.RowSpan="2" Template="{StaticResource InvisibleThumbTemplate}"
           Width="6" HorizontalAlignment="Right" VerticalAlignment="Stretch" Margin="0,12" Cursor="RightSide" />
    <Thumb x:Name="ResizeTop" Grid.Row="0" Grid.RowSpan="2" Template="{StaticResource InvisibleThumbTemplate}"
           Height="6" HorizontalAlignment="Stretch" VerticalAlignment="Top" Margin="12,0" Cursor="TopSide" />
    <Thumb x:Name="ResizeBottom" Grid.Row="0" Grid.RowSpan="2" Template="{StaticResource InvisibleThumbTemplate}"
           Height="6" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Margin="12,0" Cursor="BottomSide" />
    <Thumb x:Name="ResizeTopLeft" Grid.Row="0" Grid.RowSpan="2" Template="{StaticResource InvisibleThumbTemplate}"
           Width="12" Height="12" HorizontalAlignment="Left" VerticalAlignment="Top" Cursor="TopLeftCorner" />
    <Thumb x:Name="ResizeTopRight" Grid.Row="0" Grid.RowSpan="2" Template="{StaticResource InvisibleThumbTemplate}"
           Width="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Top" Cursor="TopRightCorner" />
    <Thumb x:Name="ResizeBottomLeft" Grid.Row="0" Grid.RowSpan="2" Template="{StaticResource InvisibleThumbTemplate}"
           Width="12" Height="12" HorizontalAlignment="Left" VerticalAlignment="Bottom" Cursor="BottomLeftCorner" />
  </Grid>
</Window>
