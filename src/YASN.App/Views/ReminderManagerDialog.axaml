<Window
    x:Class="YASN.Views.ReminderManagerDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:l="clr-namespace:YASN.Localization"
    xmlns:views="clr-namespace:YASN.Views"
    Title="{l:Tr Reminder.Manager.Title}"
    Width="460"
    Height="360"
    WindowStartupLocation="CenterOwner"
    CanResize="True">
  <DockPanel Margin="16" LastChildFill="True">
    <TextBlock DockPanel.Dock="Top"
               Text="{l:Tr Reminder.Manager.Title}"
               FontWeight="SemiBold"
               Margin="0,0,0,12" />
    <StackPanel DockPanel.Dock="Bottom"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8"
                Margin="0,12,0,0">
      <Button Content="{l:Tr Reminder.Manager.Close}" Click="HandleCloseClick" />
    </StackPanel>
    <TextBlock x:Name="EmptyLabel"
               Text="{l:Tr Reminder.Manager.Empty}"
               Foreground="#777777"
               IsVisible="False" />
    <Border BorderBrush="#33000000" BorderThickness="1" CornerRadius="4">
      <ScrollViewer>
        <ItemsControl x:Name="ItemsList">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="views:ReminderRow">
              <Grid Margin="10,8" ColumnDefinitions="*,Auto,Auto,Auto" RowDefinitions="Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding DisplayText}" FontWeight="Medium" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding Summary}" Foreground="#777777" FontSize="12" TextTrimming="CharacterEllipsis" />
                <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Margin="6,0,0,0"
                        Content="{Binding ToggleLabel}" Tag="{Binding}" Click="HandleToggleClick" />
                <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="2" Margin="6,0,0,0"
                        Content="{l:Tr Reminder.Manager.Edit}" Tag="{Binding}" Click="HandleEditClick" />
                <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="3" Margin="6,0,0,0"
                        Content="{l:Tr Reminder.Manager.Delete}" Tag="{Binding}" Click="HandleDeleteClick" />
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>
  </DockPanel>
</Window>
