namespace YASN
{
    /// <summary>
    /// Interaction logic for MainWindow.xaml
    /// </summary>
    public partial class MainWindow : Window
    {
        public MainWindow()
        {
            InitializeComponent();
        }

        private void CreateTopWindow_Click(object sender, RoutedEventArgs e)
        {
            var window = new FloatingWindow(WindowLevel.TopMost);
            window.Show();
        }

        private void CreateBottomWindow_Click(object sender, RoutedEventArgs e)
        {
            var window = new FloatingWindow(WindowLevel.BottomMost);
            window.Show();
        }

        private void CreateNormalWindow_Click(object sender, RoutedEventArgs e)
        {
            var window = new FloatingWindow(WindowLevel.Normal);
            window.Show();
        }

        private void HideToTray_Click(object sender, RoutedEventArgs e)
        {
            this.Hide();
        }

        protected override void OnClosing(System.ComponentModel.CancelEventArgs e)
        {
            // Hide to tray instead of closing
            e.Cancel = true;
            this.Hide();
        }
    }
}