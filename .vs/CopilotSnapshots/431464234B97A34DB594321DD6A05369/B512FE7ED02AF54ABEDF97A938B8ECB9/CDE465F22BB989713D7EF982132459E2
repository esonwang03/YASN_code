using System;
using System.Windows;
using System.Windows.Input;
using System.Windows.Media;
using System.Windows.Interop;
using System.Runtime.InteropServices;

namespace YASN
{
    public enum WindowLevel
    {
        Normal,
        TopMost,
        BottomMost
    }

    /// <summary>
    /// Unified floating window with adjustable Z-order
    /// </summary>
    public partial class FloatingWindow : Window
    {
        private static readonly IntPtr HWND_BOTTOM = new IntPtr(1);
        private static readonly IntPtr HWND_NOTOPMOST = new IntPtr(-2);
        
        private const uint SWP_NOSIZE = 0x0001;
        private const uint SWP_NOMOVE = 0x0002;
        private const uint SWP_NOACTIVATE = 0x0010;
        private const uint SWP_SHOWWINDOW = 0x0040;

        [DllImport("user32.dll", SetLastError = true)]
        private static extern bool SetWindowPos(IntPtr hWnd, IntPtr hWndInsertAfter, int X, int Y, int cx, int cy, uint uFlags);

        private IntPtr _hwnd;
        private System.Windows.Threading.DispatcherTimer _timer;
        private WindowLevel _currentLevel = WindowLevel.Normal;
        private static int _windowCounter = 0;

        // 统一的颜色方案
        private static readonly Color TitleBarColor = Color.FromArgb(230, 45, 45, 48);      // 深灰色标题栏
        private static readonly Color ContentBgColor = Color.FromArgb(200, 30, 30, 30);     // 半透明黑色内容区

        // 三种层级的边框颜色
        private static readonly Color TopMostBorderColor = Color.FromRgb(52, 152, 219);     // 明亮蓝色
        private static readonly Color NormalBorderColor = Color.FromRgb(149, 165, 166);     // 中性灰色
        private static readonly Color BottomBorderColor = Color.FromRgb(231, 76, 60);       // 明亮红色

        public FloatingWindow() : this(WindowLevel.Normal)
        {
        }

        public FloatingWindow(WindowLevel level)
        {
            InitializeComponent();
            _windowCounter++;
            
            SetWindowLevel(level);
            UpdateWindowAppearance();
            
            // 设置默认标题
            UpdateTitle();
            ContentTextBox.Text = "Enter your notes here...\n\nRight-click to change window level or close.";
            
            // 初始化定时器（用于底层窗口）
            _timer = new System.Windows.Threading.DispatcherTimer();
            _timer.Interval = TimeSpan.FromMilliseconds(100);
            _timer.Tick += Timer_Tick;
        }

        private void Timer_Tick(object sender, EventArgs e)
        {
            if (_currentLevel == WindowLevel.BottomMost && _hwnd != IntPtr.Zero)
            {
                SetWindowPos(_hwnd, HWND_BOTTOM, 0, 0, 0, 0, 
                    SWP_NOMOVE | SWP_NOSIZE | SWP_NOACTIVATE);
            }
        }

        private void Window_Loaded(object sender, RoutedEventArgs e)
        {
            _hwnd = new WindowInteropHelper(this).Handle;
            ApplyWindowLevel();
        }

        private void Window_MouseLeftButtonDown(object sender, MouseButtonEventArgs e)
        {
            if (e.ButtonState == MouseButtonState.Pressed)
            {
                try
                {
                    this.DragMove();
                }
                catch { }
                
                if (_currentLevel == WindowLevel.BottomMost)
                {
                    ApplyWindowLevel();
                }
            }
        }

        private void TitleBar_MouseRightButtonDown(object sender, MouseButtonEventArgs e)
        {
            // 显示右键菜单
            MainBorder.ContextMenu.IsOpen = true;
        }

        private void CloseButton_Click(object sender, RoutedEventArgs e)
        {
            _timer?.Stop();
            this.Close();
        }

        private void MenuClose_Click(object sender, RoutedEventArgs e)
        {
            _timer?.Stop();
            this.Close();
        }

        private void MenuTopmost_Click(object sender, RoutedEventArgs e)
        {
            SetWindowLevel(WindowLevel.TopMost);
        }

        private void MenuNormal_Click(object sender, RoutedEventArgs e)
        {
            SetWindowLevel(WindowLevel.Normal);
        }

        private void MenuBottom_Click(object sender, RoutedEventArgs e)
        {
            SetWindowLevel(WindowLevel.BottomMost);
        }

        private void SetWindowLevel(WindowLevel level)
        {
            _currentLevel = level;
            
            // 更新菜单选中状态
            MenuTopmost.IsChecked = (level == WindowLevel.TopMost);
            MenuNormal.IsChecked = (level == WindowLevel.Normal);
            MenuBottom.IsChecked = (level == WindowLevel.BottomMost);
            
            // 更新窗口外观
            UpdateWindowAppearance();
            
            // 应用窗口层级
            if (_hwnd != IntPtr.Zero)
            {
                ApplyWindowLevel();
            }
        }

        private void UpdateTitle()
        {
            string levelText = _currentLevel switch
            {
                WindowLevel.TopMost => "⬆ Top",
                WindowLevel.BottomMost => "⬇ Bottom",
                _ => "⬌ Normal"
            };
            
            TitleText.Text = $"Note #{_windowCounter} {levelText}";
        }

        private void UpdateWindowAppearance()
        {
            // 统一标题栏样式
            TitleBar.Background = new SolidColorBrush(TitleBarColor);
            
            // 统一内容区背景（已在XAML中设置）
            
            // 根据层级设置边框颜色
            Color borderColor = _currentLevel switch
            {
                WindowLevel.TopMost => TopMostBorderColor,
                WindowLevel.BottomMost => BottomBorderColor,
                _ => NormalBorderColor
            };
            
            MainBorder.BorderBrush = new SolidColorBrush(borderColor);
            
            // 更新标题
            UpdateTitle();
        }

        private void ApplyWindowLevel()
        {
            if (_hwnd == IntPtr.Zero)
                return;

            _timer.Stop();

            switch (_currentLevel)
            {
                case WindowLevel.TopMost:
                    this.Topmost = true;
                    break;

                case WindowLevel.BottomMost:
                    this.Topmost = false;
                    // 先取消置顶
                    SetWindowPos(_hwnd, HWND_NOTOPMOST, 0, 0, 0, 0, 
                        SWP_NOMOVE | SWP_NOSIZE | SWP_NOACTIVATE | SWP_SHOWWINDOW);
                    // 然后置于底层
                    SetWindowPos(_hwnd, HWND_BOTTOM, 0, 0, 0, 0, 
                        SWP_NOMOVE | SWP_NOSIZE | SWP_NOACTIVATE | SWP_SHOWWINDOW);
                    // 启动定时器维护底层位置
                    _timer.Start();
                    break;

                case WindowLevel.Normal:
                default:
                    this.Topmost = false;
                    SetWindowPos(_hwnd, HWND_NOTOPMOST, 0, 0, 0, 0, 
                        SWP_NOMOVE | SWP_NOSIZE | SWP_NOACTIVATE | SWP_SHOWWINDOW);
                    break;
            }
        }

        protected override void OnSourceInitialized(EventArgs e)
        {
            base.OnSourceInitialized(e);
            _hwnd = new WindowInteropHelper(this).Handle;
        }

        protected override void OnActivated(EventArgs e)
        {
            base.OnActivated(e);
            if (_currentLevel == WindowLevel.BottomMost && _hwnd != IntPtr.Zero)
            {
                Dispatcher.BeginInvoke(new Action(() => ApplyWindowLevel()), 
                    System.Windows.Threading.DispatcherPriority.Background);
            }
        }

        protected override void OnClosed(EventArgs e)
        {
            _timer?.Stop();
            base.OnClosed(e);
        }
    }
}
