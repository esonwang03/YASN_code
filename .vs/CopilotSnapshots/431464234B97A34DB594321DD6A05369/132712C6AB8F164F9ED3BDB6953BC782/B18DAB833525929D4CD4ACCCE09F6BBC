<Window x:Class="YASN.FloatingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Floating Window" 
        Height="300" 
        Width="400"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Loaded="Window_Loaded">
    
    <Window.Resources>
        <Style x:Key="ContentTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#ECF0F1"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="CaretBrush" Value="#3498DB"/>
        </Style>
    </Window.Resources>
    
    <Border x:Name="MainBorder" 
            BorderThickness="3" 
            CornerRadius="8" 
            Background="#C81E1E1E">
        <TextBox x:Name="ContentTextBox"
                 Style="{StaticResource ContentTextBoxStyle}"/>

        <Border.ContextMenu>
            <ContextMenu Background="#2C3E50" 
                         Foreground="White"
                         BorderBrush="#34495E"
                         BorderThickness="1">
                <ContextMenu.Resources>
                    <Style TargetType="MenuItem">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="#2C3E50"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#34495E"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                    <Style TargetType="Separator">
                        <Setter Property="Background" Value="#34495E"/>
                    </Style>
                </ContextMenu.Resources>
                
                <MenuItem Header="Window Level" FontWeight="SemiBold">
                    <MenuItem x:Name="MenuTopmost" 
                              Header="▲ Always on Top" 
                              Click="MenuTopmost_Click" 
                              IsCheckable="True"/>
                    <MenuItem x:Name="MenuNormal" 
                              Header="■ Normal" 
                              Click="MenuNormal_Click" 
                              IsCheckable="True" 
                              IsChecked="True"/>
                    <MenuItem x:Name="MenuBottom" 
                              Header="▼ Always on Bottom" 
                              Click="MenuBottom_Click" 
                              IsCheckable="True"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="✕ Close Window" 
                          Click="MenuClose_Click"
                          FontWeight="SemiBold"/>
            </ContextMenu>
        </Border.ContextMenu>
    </Border>
</Window>
