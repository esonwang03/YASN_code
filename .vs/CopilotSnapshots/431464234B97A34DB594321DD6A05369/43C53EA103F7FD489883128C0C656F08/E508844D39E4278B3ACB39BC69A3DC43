<Window x:Class="YASN.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:YASN"
        mc:Ignorable="d"
        Title="YASN - Window Manager" 
        Height="350" 
        Width="500"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#F0F0F0">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
            <TextBlock Text="YASN - Yet Another Sticky Notes" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>
            
            <TextBlock Text="Floating Window Manager" 
                       FontSize="16" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30"
                       Foreground="#666"/>
            
            <Border Background="White" 
                    BorderBrush="#CCC" 
                    BorderThickness="1" 
                    CornerRadius="5"
                    Padding="20"
                    Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="How to use:" 
                               FontWeight="Bold" 
                               FontSize="14"
                               Margin="0,0,0,10"/>
                    
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,5">
                        <Run Text="• Right-click the system tray icon to create windows"/>
                    </TextBlock>
                    
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,5">
                        <Run Text="• Right-click window to change its level (Top/Normal/Bottom)"/>
                    </TextBlock>
                    
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,5">
                        <Run Text="• Drag windows to move, resize from corners"/>
                    </TextBlock>
                    
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,5">
                        <Run Text="• Use windows as sticky notes on your desktop"/>
                    </TextBlock>
                </StackPanel>
            </Border>
            
            <Button Content="Create Top Window" 
                    Padding="20,10" 
                    Margin="0,5"
                    Click="CreateTopWindow_Click"
                    Background="#1E90FF"
                    Foreground="White"
                    BorderThickness="0"
                    FontSize="14"
                    Cursor="Hand"/>
            
            <Button Content="Create Normal Window" 
                    Padding="20,10" 
                    Margin="0,5"
                    Click="CreateNormalWindow_Click"
                    Background="#808080"
                    Foreground="White"
                    BorderThickness="0"
                    FontSize="14"
                    Cursor="Hand"/>
            
            <Button Content="Create Bottom Window" 
                    Padding="20,10" 
                    Margin="0,5"
                    Click="CreateBottomWindow_Click"
                    Background="#FF6347"
                    Foreground="White"
                    BorderThickness="0"
                    FontSize="14"
                    Cursor="Hand"/>
            
            <Button Content="Hide to Tray" 
                    Padding="20,10" 
                    Margin="0,15,0,0"
                    Click="HideToTray_Click"
                    Background="#999"
                    Foreground="White"
                    BorderThickness="0"
                    FontSize="12"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
