<Window x:Class="YASN.TopMostWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TopMost Window" 
        Height="300" 
        Width="400"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#80000000"
        Topmost="True"
        ResizeMode="CanResizeWithGrip"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border BorderBrush="#FF00FF00" BorderThickness="2" CornerRadius="5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="#CC1E90FF" CornerRadius="5,5,0,0">
                <Grid>
                    <TextBlock Text="Top Most Window" 
                               VerticalAlignment="Center" 
                               HorizontalAlignment="Center"
                               Foreground="White"
                               FontWeight="Bold"/>
                    <Button Content="X" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center"
                            Width="30" 
                            Height="30"
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="20"
                            FontWeight="Bold"
                            Click="CloseButton_Click"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#CCFF0000"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Content Area -->
            <Grid Grid.Row="1" Background="#40000000">
                <TextBlock VerticalAlignment="Center" 
                           HorizontalAlignment="Center"
                           Foreground="White"
                           TextAlignment="Center"
                           FontSize="14">
                    <Run Text="Always on Top Window"/>
                    <LineBreak/><LineBreak/>
                    <Run Text="• Drag to move"/>
                    <LineBreak/>
                    <Run Text="• Resizable"/>
                    <LineBreak/>
                    <Run Text="• Click X to close"/>
                </TextBlock>
            </Grid>
        </Grid>
    </Border>
</Window>
