<Window x:Class="YASN.WebDavConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WebDAV Cloud Sync Settings" 
        Height="450" 
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="20,15">
            <TextBlock Text="WebDAV Cloud Sync Configuration" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       Foreground="White"/>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20">
            <StackPanel>
                <!-- Server URL -->
                <TextBlock Text="Server URL" 
                           FontSize="14" 
                           FontWeight="SemiBold"
                           Foreground="#2C3E50"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="ServerUrlTextBox" 
                         Height="32"
                         Padding="8"
                         Margin="0,0,0,5"
                         FontSize="13"
                         Text="https://dav.jianguoyun.com/dav/"/>
                <TextBlock FontSize="11" 
                           Foreground="#7F8C8D"
                           TextWrapping="Wrap"
                           Margin="0,0,0,15">
                    <Run Text="Example: "/>
                    <Run Text="https://dav.jianguoyun.com/dav/" FontWeight="SemiBold"/>
                    <LineBreak/>
                    <Run Text="Note: Keep the base URL, specify folder in Remote Directory below" Foreground="#E74C3C"/>
                </TextBlock>

                <!-- Username -->
                <TextBlock Text="Username / Email" 
                           FontSize="14" 
                           FontWeight="SemiBold"
                           Foreground="#2C3E50"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="UsernameTextBox" 
                         Height="32"
                         Padding="8"
                         Margin="0,0,0,15"
                         FontSize="13"/>

                <!-- Password -->
                <TextBlock Text="Password / App Token" 
                           FontSize="14" 
                           FontWeight="SemiBold"
                           Foreground="#2C3E50"
                           Margin="0,0,0,5"/>
                <PasswordBox x:Name="PasswordBox" 
                             Height="32"
                             Padding="8"
                             Margin="0,0,0,15"
                             FontSize="13"/>

                <!-- Remote Directory -->
                <TextBlock Text="Remote Directory" 
                           FontSize="14" 
                           FontWeight="SemiBold"
                           Foreground="#2C3E50"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="RemoteDirectoryTextBox" 
                         Height="32"
                         Padding="8"
                         Margin="0,0,0,5"
                         FontSize="13"
                         Text="/MyJianGuoYun/YASN"/>
                <TextBlock FontSize="11" 
                           Foreground="#7F8C8D"
                           TextWrapping="Wrap"
                           Margin="0,0,0,15">
                    <Run Text="Files will be stored in this directory"/>
                    <LineBreak/>
                    <Run Text="Jianguoyun example: /MyJianGuoYun/YASN or /YASN" Foreground="#E67E22" FontWeight="SemiBold"/>
                    <LineBreak/>
                    <Run Text="Important: Create the folder in web UI first!" Foreground="#E74C3C" FontWeight="SemiBold"/>
                </TextBlock>

                <!-- Auto Sync -->
                <Grid Margin="0,5,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Enable Auto Sync" 
                                   FontSize="14" 
                                   FontWeight="SemiBold"
                                   Foreground="#2C3E50"/>
                        <TextBlock Text="Automatically sync every 5 minutes" 
                                   FontSize="11" 
                                   Foreground="#7F8C8D"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                    
                    <CheckBox x:Name="AutoSyncCheckBox" 
                              Grid.Column="1" 
                              VerticalAlignment="Center"
                              Margin="10,0,0,0"/>
                </Grid>

                <!-- Status -->
                <Border Background="White" 
                        BorderBrush="#DDD" 
                        BorderThickness="1" 
                        CornerRadius="5" 
                        Padding="15"
                        Margin="0,5,0,0">
                    <StackPanel>
                        <TextBlock x:Name="StatusText" 
                                   Text="Not configured" 
                                   FontSize="13" 
                                   Foreground="#7F8C8D"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="LastSyncText" 
                                   FontSize="12" 
                                   Foreground="#95A5A6"
                                   Margin="0,5,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <Border Grid.Row="2" 
                Background="White" 
                BorderBrush="#DDD" 
                BorderThickness="0,1,0,0" 
                Padding="20,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Test Connection" 
                        Click="TestConnection_Click"
                        Padding="15,8"
                        Margin="0,0,10,0"
                        Background="#3498DB"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="13"
                        Cursor="Hand"/>
                
                <Button Content="Save &amp; Enable" 
                        Click="Save_Click"
                        Padding="20,8"
                        Margin="0,0,10,0"
                        Background="#27AE60"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="13"
                        Cursor="Hand"/>
                
                <Button Content="Close" 
                        Click="Close_Click"
                        Padding="20,8"
                        Background="#95A5A6"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="13"
                        Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
