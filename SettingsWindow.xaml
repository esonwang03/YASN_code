<Window x:Class="YASN.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:YASN"
        mc:Ignorable="d"
        Title="Settings - YASN" 
        Height="400" 
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="20,15">
            <TextBlock Text="Application Settings" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       Foreground="White"/>
        </Border>

        <!-- Settings Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20">
            <StackPanel>
                <!-- General Settings -->
                <Border Background="White" 
                        BorderBrush="#DDD" 
                        BorderThickness="1" 
                        CornerRadius="5" 
                        Padding="20"
                        Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="General Settings" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,15"
                                   Foreground="#2C3E50"/>
                        
                        <!-- Auto Start -->
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Auto Start on Windows Startup" 
                                           FontSize="14" 
                                           FontWeight="SemiBold"
                                           Foreground="#34495E"/>
                                <TextBlock Text="Automatically run YASN when Windows starts" 
                                           FontSize="12" 
                                           Foreground="#7F8C8D"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            
                            <CheckBox x:Name="AutoStartCheckBox" 
                                      Grid.Column="1" 
                                      VerticalAlignment="Center"
                                      Checked="AutoStartCheckBox_Changed"
                                      Unchecked="AutoStartCheckBox_Changed"
                                      Margin="10,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Cloud Sync Settings -->
                <Border Background="White" 
                        BorderBrush="#DDD" 
                        BorderThickness="1" 
                        CornerRadius="5" 
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="Cloud Sync (WebDAV)" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,15"
                                   Foreground="#2C3E50"/>
                        
                        <!-- WebDAV Config Button -->
                        <Button Content="Configure WebDAV Sync" 
                                Click="ConfigureWebDav_Click"
                                Padding="15,10"
                                Background="#3498DB"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="13"
                                Cursor="Hand"
                                HorizontalAlignment="Left"/>
                        
                        <TextBlock Text="Sync your notes across devices using WebDAV" 
                                   FontSize="11" 
                                   Foreground="#7F8C8D"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
